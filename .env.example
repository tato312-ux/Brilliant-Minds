# General settings
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
# AI Project Settings
AZURE_AI_PROJECT_ENDPOINT=<your-ai-project-endpoint>
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=<your-ai-model-deployment-name>
AI_PROJECT_RESOURCE_ID=<your-project-resource-id>
AI_PROJECT_NAME=<your-ai-project-name>
AI_MODEL_NAME=gpt-4.1-mini
AI_PROJECT_CONNECTION_NAME=rag-mcp-connection  # name of the project connection that points to the MCP tool

# Generative Model *gpt-4.1-mini()
AOAI_ENDPOINT=<your-generative-model-endpoint>
AOAI_KEY=<your-generative-model-key>
AOAI_DEPLOYMENT_NAME=<your-generative-model-deployment-name>

# Embedding Model
EMBEDDING_MODEL_DEPLOYMENT_NAME=text-embedding-3-large
EMBEDDING_MODEL_NAME=text-embedding-3-large

# Azure Blob Storage Settings
AZURE_STORAGE_CONNECTION_STRING=<your-storage-connection-string>
AZURE_STORAGE_CONTAINER=<your-container-name>
AZURE_BLOB_STORAGE_URL=<your-blob-storage-url>

# Azure AI Search
AI_SEARCH_ENDPOINT=<your-ai-search-endpoint>
AI_SEARCH_KEY=<your-ai-search-apikey>
AI_SEARCH_INDEX_NAME=<your-ai-search-index-name>

# Knowledge Source Defaults
KNOWLEDGE_SOURCE_NAME=ks-mypdf-v1
KNOWLEDGE_SOURCE_DESCRIPTION="Automated knowledge source from Blob containing my PDF"

# Knowledge Base Defautls
KNOWLEDGE_BASE_NAME=kb-mypdf-v1
KNOWLEDGE_BASE_DESCRIPTION="Agentic RAG knowledge base built from my PDF"
KNOWLEDGE_BASE_ANSWER_INSTRUCTIONS="Cite the PDF page for every statement, and keep answers concise."
KNOWLEDGE_BASE_RETRIEVAL_INSTRUCTIONS="Retrieve passages that match the user intent, prioritize the most recent sections, and keep citation metadata intact."

# Redis Settings
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=chat_msg

# DB Path
AUTH_DB_PATH=data/user.db
# JWT Settings
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ALLOW_INSECURE_DEV_JWT=false

LAYOUT_RAG_ENABLED=false
LAYOUT_RAG_INDEX_NAME=documents-layout-rag-v2
LAYOUT_RAG_DATASOURCE_NAME=documents-layout-rag-v2-datasource
LAYOUT_RAG_SKILLSET_NAME=documents-layout-rag-v2-skillset
LAYOUT_RAG_INDEXER_NAME=documents-layout-rag-v2-indexer
LAYOUT_RAG_MAX_CHUNK_LENGTH=2000
LAYOUT_RAG_OVERLAP_LENGTH=200
LAYOUT_RAG_ENABLE_IMAGE_REFERENCES=true
LAYOUT_RAG_CONTENT_FIELD=content
LAYOUT_RAG_VECTOR_FIELD=content_vector
LAYOUT_RAG_TITLE_FIELD=document_title
LAYOUT_RAG_PATH_FIELD=metadata_storage_path
LAYOUT_RAG_PAGE_FIELD=page_number
RAG_V3_ENABLED=false
RAG_V3_INDEX_NAME=documents-layout-rag-v3
RAG_V3_DATASOURCE_NAME=documents-layout-rag-v3-datasource
RAG_V3_SKILLSET_NAME=documents-layout-rag-v3-skillset
RAG_V3_INDEXER_NAME=documents-layout-rag-v3-indexer
RAG_V3_IMAGE_INDEX_NAME=documents-layout-rag-v3-images
RAG_V3_CONTENT_FIELD=content
RAG_V3_VECTOR_FIELD=content_vector
RAG_V3_IMAGE_VECTOR_FIELD=image_vector
RAG_V3_TITLE_FIELD=document_title
RAG_V3_PATH_FIELD=metadata_storage_path
RAG_V3_PAGE_FIELD=page_number
RAG_V3_IMAGE_PATH_FIELD=image_path
RAG_V3_IMAGE_CAPTION_FIELD=image_caption
RAG_V3_SOURCE_KIND_FIELD=source_kind
RAG_V3_SECTION_KIND_FIELD=section_kind

# ── Azure Document Intelligence ──────────────────────────────────────────────
DOCUMENT_INTELLIGENCE_ENDPOINT=<your-doc-intelligence-endpoint>
DOCUMENT_INTELLIGENCE_KEY=<your-doc-intelligence-key>

